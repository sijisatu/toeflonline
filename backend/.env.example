# =============================================================================
# backend/.env.example
# Generic environment template — copy to .env and fill in real values.
#
# For local development:  see backend/.env.local.example
# For Railway production: see backend/.env.production.example
# =============================================================================

# --- Server ------------------------------------------------------------------
PORT=8080
APP_ENV=development

# Comma-separated list of allowed CORS origins.
# Add your Railway public domain once it is assigned.
APP_ORIGIN=http://localhost:5173,http://localhost:4173,https://your-app.up.railway.app

BACKEND_TLS_ENABLED=false

# --- JWT ---------------------------------------------------------------------
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-min-32-chars

# --- PostgreSQL --------------------------------------------------------------
# Railway reference syntax (used when this service is deployed on Railway):
#   POSTGRES_HOST=${{Postgres.PGHOST}}
#   POSTGRES_PORT=${{Postgres.PGPORT}}
#   POSTGRES_DB=${{Postgres.PGDATABASE}}
#   POSTGRES_USER=${{Postgres.PGUSER}}
#   POSTGRES_PASSWORD=${{Postgres.PGPASSWORD}}
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=toefl_online
POSTGRES_USER=toefl_app
POSTGRES_PASSWORD=change-me

# --- Redis -------------------------------------------------------------------
# Railway reference syntax:
#   REDIS_HOST=${{Redis.REDISHOST}}
#   REDIS_PORT=${{Redis.REDISPORT}}
#   REDIS_PASSWORD=${{Redis.REDISPASSWORD}}
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Proctoring --------------------------------------------------------------
PROCTORING_SNAPSHOT_PATH=storage/proctoring
