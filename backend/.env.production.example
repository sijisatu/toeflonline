PORT=8080
APP_ENV=production
APP_ORIGIN=https://toeflonline-production.up.railway.app
BACKEND_TLS_ENABLED=false
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret

# PostgreSQL — Railway injects these automatically via service variable references
POSTGRES_HOST=${{ Postgres.PGHOST }}
POSTGRES_PORT=${{ Postgres.PGPORT }}
POSTGRES_DB=${{ Postgres.PGDATABASE }}
POSTGRES_USER=${{ Postgres.PGUSER }}
POSTGRES_PASSWORD=${{ Postgres.PGPASSWORD }}

# Redis — update if a Redis service is provisioned on Railway
REDIS_HOST=${{ Redis.REDIS_HOST }}
REDIS_PORT=${{ Redis.REDIS_PORT }}
REDIS_PASSWORD=${{ Redis.REDIS_PASSWORD }}

PROCTORING_SNAPSHOT_PATH=storage/proctoring
