# =============================================================================
# backend/.env.local.example
# Local development environment — copy to backend/.env and adjust as needed.
#
# Prerequisites:
#   1. Start local infrastructure:
#        docker compose -f infra/docker-compose.local.yml up -d
#      This starts PostgreSQL on localhost:5432 and Redis on localhost:6379
#      using the credentials below.
#
#   2. Initialise the database (first time only):
#        ./scripts/init-db.sh
#      Or without demo seed data:
#        ./scripts/init-db.sh --no-seed
#
#   3. Start the backend:
#        cd backend && npm run dev
# =============================================================================

# --- Server ------------------------------------------------------------------
PORT=4000
APP_ENV=development

# Frontend dev server origins (Vite default ports)
APP_ORIGIN=http://localhost:5173,http://localhost:4173

BACKEND_TLS_ENABLED=false

# --- JWT ---------------------------------------------------------------------
# These placeholder values are fine for local development only.
# Use long random secrets in any shared or production environment.
JWT_ACCESS_SECRET=local-dev-access-secret-change-in-production
JWT_REFRESH_SECRET=local-dev-refresh-secret-change-in-production

# --- PostgreSQL --------------------------------------------------------------
# Matches the docker-compose.local.yml defaults.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=toefl_online
POSTGRES_USER=toefl_app
POSTGRES_PASSWORD=change-me

# --- Redis -------------------------------------------------------------------
# Matches the docker-compose.local.yml defaults.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Proctoring --------------------------------------------------------------
PROCTORING_SNAPSHOT_PATH=storage/proctoring
